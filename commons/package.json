      "default": "./dist/util/index.js"
    }
  },
  "dependencies": {
    "big.js": "^6.2.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/big.js": "^6.2.2",
    "@types/uuid": "^9.0.7",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2"
  }
