{
  "name": "@optivem/commons",
  "version": "0.0.1",
  "description": "Shared utilities for Optivem acceptance testing (util)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "rimraf dist && tsc",
    "clean": "rimraf dist"
  },
